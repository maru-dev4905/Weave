{
  "name": "@weave/wv",
  "version": "1.0.1",
  "private": true,
  "type": "module",
  "main": "./dist/js/core.js",
  "module": "./dist/js/core.js",
  "style": "./dist/css/wv.css",
  "exports": {
    ".": "./dist/js/core.js",
    "./css/wv.css": "./dist/css/wv.css",
    "./css/common.css": "./dist/css/common.css",
    "./css/admin.css": "./dist/css/admin.css",
    "./css/gov.css": "./dist/css/gov.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "clean": "rimraf dist",
    "build:css:wv": "sass src/scss/index.scss dist/css/wv.css --no-source-map",
    "build:css:common": "sass src/scss/common.scss dist/css/common.css --no-source-map",
    "build:css:admin": "sass src/scss/admin.scss dist/css/admin.css --no-source-map",
    "build:css:gov": "sass src/scss/gov/index.scss dist/css/gov.css --no-source-map",
    "build:css": "pnpm run build:css:wv && pnpm run build:css:common && pnpm run build:css:admin && pnpm run build:css:gov && node scripts/finalize-css.mjs",
    "build:js": "vite build",
    "build": "pnpm run clean && pnpm run build:css && pnpm run build:js"
  },
  "devDependencies": {
    "esbuild": "^0.21.3",
    "rimraf": "^6.0.0",
    "sass": "^1.77.0",
    "vite": "^5.4.0"
  },
  "dependencies": {
    "gsap": "^3.14.2"
  }
}